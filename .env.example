# ═══════════════════════════════════════════════════════════════
# PGI HUB — PLATFORM API ENVIRONMENT CONFIGURATION
# ═══════════════════════════════════════════════════════════════
# Copy this file to .env and fill in values before starting.
# Lines marked [REQUIRED_PRODUCTION] will cause startup failure
# in ENVIRONMENT=production if left empty.
# Lines marked [OPTIONAL] will cause graceful feature degradation.
# Lines marked [DEV_DEFAULT] have safe defaults for local dev.
# ═══════════════════════════════════════════════════════════════

## CORE ##
ENVIRONMENT=development                # [REQUIRED_PRODUCTION] development|staging|production
DATABASE_URL=                           # [REQUIRED_PRODUCTION] postgresql+psycopg2://user:pass@host:5432/dbname
READ_REPLICA_URL=                       # [OPTIONAL] postgresql+psycopg2://... for analytics queries
REDIS_URL=redis://localhost:6379/0      # [REQUIRED_PRODUCTION] Used for: rate limiting, idempotency, worker queue
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000  # [REQUIRED_PRODUCTION] Comma-separated frontend origins

## SECURITY / JWT ##
SECRET_KEY=                             # [REQUIRED_PRODUCTION] min 64 random chars — python -c "import secrets;print(secrets.token_hex(64))"
JWT_ALGORITHM=HS256                     # [DEV_DEFAULT] Use RS256 in production
JWT_PRIVATE_KEY_PATH=                   # [REQUIRED if JWT_ALGORITHM=RS256] path to PEM private key
JWT_PUBLIC_KEY_PATH=                    # [REQUIRED if JWT_ALGORITHM=RS256] path to PEM public key
ACCESS_TOKEN_EXPIRE_MINUTES=15          # [DEV_DEFAULT]
REFRESH_TOKEN_EXPIRE_DAYS=7             # [DEV_DEFAULT]
LEGACY_HS256_ENABLED=true               # [DEV_DEFAULT] Set false once RS256 keys deployed
INTERNAL_API_KEY=                       # [REQUIRED_PRODUCTION] Shared secret for Repo C → Repo B calls

## OAUTH PROVIDERS ##
GOOGLE_CLIENT_ID=                       # [OPTIONAL] From console.cloud.google.com
GOOGLE_CLIENT_SECRET=                   # [OPTIONAL]
LINKEDIN_CLIENT_ID=                     # [OPTIONAL] From linkedin.com/developers/apps
LINKEDIN_CLIENT_SECRET=                 # [OPTIONAL]
MICROSOFT_CLIENT_ID=                    # [OPTIONAL] From portal.azure.com → App registrations
MICROSOFT_CLIENT_SECRET=                # [OPTIONAL]
MICROSOFT_TENANT_ID=common              # [DEV_DEFAULT] Use specific tenant ID for enterprise apps
SAML_METADATA_URL=                      # [OPTIONAL] For enterprise SSO (SAML 2.0)

## BOM INTELLIGENCE ENGINE (Repo B) ##
BOM_ANALYZER_URL=http://localhost:8001  # [REQUIRED_PRODUCTION] URL of the BOM Intelligence Engine

## GUEST SESSION ##
GUEST_SESSION_COOKIE_NAME=pgi_guest     # [DEV_DEFAULT]
GUEST_SESSION_MAX_AGE_DAYS=30           # [DEV_DEFAULT]

## OBJECT STORAGE (S3 / MinIO) ##
S3_BUCKET=                              # [REQUIRED_PRODUCTION] Bucket name for document vault
S3_REGION=us-east-1                     # [DEV_DEFAULT]
S3_ACCESS_KEY_ID=                       # [REQUIRED_PRODUCTION]
S3_SECRET_ACCESS_KEY=                   # [REQUIRED_PRODUCTION]
S3_ENDPOINT_URL=                        # [OPTIONAL] http://localhost:9000 for local MinIO

## DISTRIBUTOR APIs ##
DIGIKEY_CLIENT_ID=                      # [OPTIONAL] From developer.digikey.com
DIGIKEY_CLIENT_SECRET=                  # [OPTIONAL]
MOUSER_API_KEY=                         # [OPTIONAL] From mouser.com/api
OCTOPART_API_KEY=                       # [OPTIONAL] From octopart.com/api
ARROW_API_KEY=                          # [OPTIONAL] From arrow.com/en/products/research/api

## MARKET DATA APIs ##
OPEN_EXCHANGE_RATES_APP_ID=             # [OPTIONAL] From openexchangerates.org
XE_API_KEY=                             # [OPTIONAL] From xe.com/xecurrencydata
LME_API_KEY=                            # [OPTIONAL] London Metal Exchange
FASTMARKETS_API_KEY=                    # [OPTIONAL] fastmarkets.com

## LOGISTICS / CARRIER APIs ##
AFTERSHIP_API_KEY=                      # [OPTIONAL] From aftership.com
AFTERSHIP_WEBHOOK_SECRET=               # [OPTIONAL] Webhook HMAC validation
DHL_API_KEY=                            # [OPTIONAL] From developer.dhl.com
DHL_API_SECRET=                         # [OPTIONAL]
FEDEX_API_KEY=                          # [OPTIONAL] From developer.fedex.com
UPS_CLIENT_ID=                          # [OPTIONAL] From developer.ups.com
UPS_CLIENT_SECRET=                      # [OPTIONAL]

## NOTIFICATION PROVIDERS ##
SENDGRID_API_KEY=                       # [OPTIONAL] From sendgrid.com
SENDGRID_FROM_EMAIL=noreply@pgihub.com  # [OPTIONAL] Verified sender
TWILIO_ACCOUNT_SID=                     # [OPTIONAL] From twilio.com
TWILIO_AUTH_TOKEN=                      # [OPTIONAL]
TWILIO_FROM_NUMBER=                     # [OPTIONAL] E.164: +1234567890
FIREBASE_CREDENTIALS_PATH=             # [OPTIONAL] Firebase service account JSON path
FIREBASE_PROJECT_ID=                    # [OPTIONAL]

## GEOLOCATION ##
MAXMIND_ACCOUNT_ID=                     # [OPTIONAL] From maxmind.com
MAXMIND_LICENSE_KEY=                    # [OPTIONAL]
MAXMIND_DB_PATH=./data/GeoLite2-City.mmdb  # [OPTIONAL] Local GeoIP2 DB path

## VIRUS SCANNING ##
CLAMAV_HOST=localhost                   # [OPTIONAL] ClamAV server host
CLAMAV_PORT=3310                        # [DEV_DEFAULT]

## OBSERVABILITY ##
OTEL_ENABLED=false                      # [DEV_DEFAULT] Set true for OpenTelemetry
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4317  # [OPTIONAL] Jaeger/Grafana OTLP
OTEL_SERVICE_NAME=platform-api          # [DEV_DEFAULT]

## EVENT BROKER ##
EVENT_BROKER_URL=                       # [OPTIONAL] Kafka/RabbitMQ URL (future)
EVENT_BROKER_TYPE=memory                # [DEV_DEFAULT] memory|kafka|rabbitmq

## LEGACY ##
UPLOAD_DIR=./uploads                    # [DEV_DEFAULT] Use S3 in production
