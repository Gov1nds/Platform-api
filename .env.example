# PGI Platform API — Environment Variables

# Database (PostgreSQL recommended, SQLite fallback for dev)
DATABASE_URL=sqlite:///./pgi_platform.db
# DATABASE_URL=postgresql://user:password@localhost:5432/pgi_platform

# JWT Secret (CHANGE IN PRODUCTION)
SECRET_KEY=pgi-production-secret-change-this-immediately
ACCESS_TOKEN_EXPIRE_MINUTES=1440

# External Supplier APIs (optional — system works without these)
OCTOPART_API_KEY=
MOUSER_API_KEY=
DIGIKEY_CLIENT_ID=
DIGIKEY_CLIENT_SECRET=
MISUMI_API_KEY=

# File uploads
UPLOAD_DIR=./uploads
