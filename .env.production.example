# ═══════════════════════════════════════════════════════════
# PGI Platform — Production Environment Configuration
# ═══════════════════════════════════════════════════════════
#
# STARTUP POLICY:
#   - ENVIRONMENT=production disables Base.metadata.create_all()
#   - Schema changes MUST go through Alembic migrations:
#       alembic revision --autogenerate -m "description"
#       alembic upgrade head
#   - To emergency-bootstrap a fresh DB, temporarily set ALLOW_CREATE_ALL=true
#     then immediately revert after tables are created.
#
# DRAWING STORAGE POLICY:
#   - Production REQUIRES S3/object storage for drawings
#   - DRAWING_STORAGE_PROVIDER=local will FAIL FAST in production
#   - Local storage is dev-only (ephemeral on Railway/Docker)
#
# ═══════════════════════════════════════════════════════════

# ── Core ──
ENVIRONMENT=production
ALLOW_CREATE_ALL=false

# ── Database ──
DATABASE_URL=postgresql+psycopg2://user:password@host:5432/pgi_platform

# ── JWT ──
SECRET_KEY=<generate-a-strong-random-secret-minimum-32-chars>
ACCESS_TOKEN_EXPIRE_MINUTES=1440

# ── Drawing Storage (REQUIRED in production) ──
DRAWING_STORAGE_PROVIDER=s3
DRAWING_S3_BUCKET=pgi-drawings-prod
DRAWING_S3_PREFIX=drawings/
AWS_ACCESS_KEY_ID=<your-key>
AWS_SECRET_ACCESS_KEY=<your-secret>
AWS_REGION=us-east-1

# ── Email Notifications (optional but recommended) ──
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=noreply@pgihub.com
SMTP_PASS=<smtp-password>
FROM_EMAIL=noreply@pgihub.com
FROM_NAME=PGI Hub
FRONTEND_URL=https://www.pgihub.com

# ── External Pricing APIs (optional, simulated fallback without) ──
OCTOPART_API_KEY=
MOUSER_API_KEY=
DIGIKEY_CLIENT_ID=
DIGIKEY_CLIENT_SECRET=

# ── BOM Analyzer Engine ──
BOM_ANALYZER_URL=http://bom-intelligence-engine.railway.internal:8001
INTERNAL_API_KEY=<shared-secret>
